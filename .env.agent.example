# LLM API Configuration
# Copy this file to .env.agent.secret and fill in your credentials

# Qwen Code API Key (obtain from Qwen Code setup / Dashscope)
LLM_API_KEY=your_api_key_here

# Qwen Code API Base URL (Dashscope compatible mode)
LLM_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1

# Model name
LLM_MODEL=qwen3-coder-plus
