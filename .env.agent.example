# LLM API Configuration
# Copy this file to .env.agent.secret and fill in your credentials

# OpenRouter API Key (get from https://openrouter.ai/keys)
LLM_API_KEY=your_api_key_here

# OpenRouter API Base URL
LLM_API_BASE=https://openrouter.ai/api/v1

# Model name (free model with :free suffix)
LLM_MODEL=qwen/qwen-2.5-coder-32b-instruct:free

# Backend API Configuration (for query_api tool)
# Default is http://localhost:42002, will be overridden by autochecker
AGENT_API_BASE_URL=http://localhost:42002
